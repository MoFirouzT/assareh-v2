# Example environment variables for Assareh
# Copy this to .env and customize locally. Do NOT commit .env.

# Paths
ASSAREH_DATA_DIR=data

# Symbol and intervals
ASSAREH_SYMBOL=BTCUSDT
ASSAREH_INTERVALS=1m,15m,1h,4h

# MLflow tracking (local file backend)
ASSAREH_MLFLOW_TRACKING_URI=file:./mlruns

# Misc
ASSAREH_RANDOM_SEED=42
ASSAREH_LOG_LEVEL=INFO
